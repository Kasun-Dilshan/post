## Backend email settings (used by server/index.js)
#
# Your SMTP provider credentials (Gmail/Zoho/SendGrid SMTP/etc)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username_or_email
SMTP_PASS=your_smtp_password_or_app_password
#
# Optional: override "from" header (defaults to SMTP_USER)
MAIL_FROM="Serendib Groups <no-reply@serendibgroups.com>"
#
# Optional: where website messages are delivered
TO_EMAIL=info@serendibgroups.com
#
# API port (Vite proxies /api to this)
PORT=5174

